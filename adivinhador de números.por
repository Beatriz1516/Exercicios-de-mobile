programa {
  funcao inicio() {
    escreva("==================================================\n")
    escreva("=     Bem-vindo ao nosso jogo de adivinhação     =\n")
    escreva("==================================================\n")

    inteiro numero_secreto, chute

    numero_secreto = 89

    escreva("Qual o seu palpite?")
